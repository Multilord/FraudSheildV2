# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# ─── FastAPI Backend ──────────────────────────────────────────────────────────
# Port for the main FastAPI server
API_PORT=8000
API_HOST=0.0.0.0

# ─── MCP Servers ─────────────────────────────────────────────────────────────
# Ports for the four MCP servers (adjust if ports are in use)
MCP_SCORING_PORT=8001
MCP_CASE_PORT=8002
MCP_NETWORK_PORT=8003
MCP_INSIGHTS_PORT=8004

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── FraudShield Runtime ──────────────────────────────────────────────────────
# Set to true to disable DB reads and return empty placeholder stats
# (useful for UI-only demos before model training)
DEMO_MODE=false
